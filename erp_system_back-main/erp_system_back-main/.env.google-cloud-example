# Google Cloud Vision API Configuration
# =========================================

# مسار ملف مفتاح Google Cloud Service Account
# يجب إنشاء Service Account من Google Cloud Console
# ثم تحميل ملف JSON وحفظه في المشروع
GOOGLE_CLOUD_KEY_FILE=./google-cloud-key.json

# أو يمكن استخدام Application Default Credentials
# بتعيين متغير البيئة:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# خطوات الحصول على المفتاح:
# 1. افتح https://console.cloud.google.com
# 2. أنشئ مشروع جديد أو اختر مشروع موجود
# 3. فعّل Google Cloud Vision API
# 4. أنشئ Service Account
# 5. أنشئ مفتاح JSON
# 6. حمّل الملف واحفظه كـ google-cloud-key.json
# 7. ضع المسار في هذا الملف

# ملاحظة: أول 1000 صورة شهرياً مجانية
# بعدها: $1.50 لكل 1000 صورة