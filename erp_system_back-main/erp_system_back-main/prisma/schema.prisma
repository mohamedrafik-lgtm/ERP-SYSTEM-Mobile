// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// نوع الحساب
enum AccountType {
  STAFF      // موظف إداري (الوصول الكامل للوحة التحكم)
  INSTRUCTOR // محاضر (وصول محدود للوحة تحكم المحاضرين)
}

model User {
  id                 String             @id @default(cuid())
  name               String
  email              String             @unique
  phone              String?            @unique // رقم الهاتف (اختياري ومميز)
  password           String
  photoUrl           String?            // رابط الصورة الشخصية
  accountType        AccountType        @default(STAFF) // نوع الحساب
  isActive           Boolean            @default(true) // حالة نشاط المستخدم
  isArchived         Boolean            @default(false) // حالة أرشفة الحساب
  lastLoginAt        DateTime?          // آخر تسجيل دخول
  // إعادة تعيين كلمة المرور
  resetCode          String?            // كود إعادة تعيين كلمة المرور
  resetCodeExpiresAt DateTime?          // تاريخ انتهاء كود إعادة التعيين
  resetCodeGeneratedAt DateTime?        // تاريخ توليد الكود
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  AuditLog           AuditLog[]
  instructorContents TrainingContent[]
  questions          Question[] // Relación con las preguntas creadas por el usuario
  attendanceRecords  AttendanceRecord[] // علاقة مع سجلات الحضور التي قام بإنشائها

  // علاقات مسؤولي تسجيل الحضور (القديم - محتفظ به)
  theoryAttendanceRecords    TrainingContent[] @relation("TheoryAttendanceRecorder")
  practicalAttendanceRecords TrainingContent[] @relation("PracticalAttendanceRecorder")
  
  // علاقة مع مسؤولية تسجيل الحضور (جديد)
  attendanceResponsibilities TrainingContentAttendance[] // المحتويات التدريبية المسؤول عن حضورها

  // العلاقة مع عمليات طباعة الكارنيهات
  idCardPrints IdCardPrint[]
  
  // العلاقة مع عمليات تسليم الكارنيهات
  deliveredIdCards IdCardPrint[] @relation("CardDeliverer")

  // علاقات نظام الصلاحيات الجديد
  userRoles       UserRole[]       // الأدوار المعينة للمستخدم
  userPermissions UserPermission[] // الصلاحيات المباشرة للمستخدم
  assignedRoles   UserRole[]       @relation("RoleAssigner") // الأدوار التي قام بتعيينها
  assignedUserPermissions UserPermission[] @relation("PermissionAssigner") // الصلاحيات التي قام بتعيينها
  
  // العلاقة مع القيود المالية
  financialEntries FinancialEntry[] // القيود المالية التي قام بإنشائها
  
  // العلاقة مع المعاملات المالية
  createdTransactions Transaction[] @relation("TransactionCreatedBy") // المعاملات التي قام بإنشائها
  
  // علاقات سجل الأنشطة
  permissionLogsAsUser  PermissionLog[] @relation("PermissionLogUser") // السجلات كمستخدم متأثر
  permissionLogsAsActor PermissionLog[] @relation("PermissionLogActor") // السجلات كفاعل
  
  // العلاقة مع أرشيف الوثائق
  uploadedDocuments     TraineeDocument[] // الوثائق التي قام برفعها
  
  // العلاقة مع ملاحظات المتدربين
  traineeNotes          TraineeNote[] // الملاحظات التي قام بتسجيلها
  
  // العلاقة مع إنشاء وتعديل المتدربين
  createdTrainees       Trainee[] @relation("TraineeCreatedBy") // المتدربون الذين قام بإنشائهم
  updatedTrainees       Trainee[] @relation("TraineeUpdatedBy") // المتدربون الذين قام بتعديلهم
  traineeEditHistory    TraineeEditHistory[] // سجل تعديلات المتدربين
  
  // العلاقة مع نظام الحضور
  recordedAttendance    Attendance[] // سجلات الحضور التي قام بتسجيلها
  updatedAttendance     Attendance[] @relation("AttendanceUpdates") // سجلات الحضور التي قام بتعديلها
  attendanceCodes       AttendanceCode[] // أكواد الحضور التي أنشأها
  
  // العلاقة مع طلبات تأجيل السداد
  reviewedDeferralRequests PaymentDeferralRequest[] // طلبات التأجيل التي راجعها
  
  // العلاقة مع مسؤولية تسليم الأدوات الدراسية
  responsibleForMaterials  StudyMaterialResponsible[] // الأدوات الدراسية المسؤول عن تسليمها
  
  // العلاقة مع طلبات المتدربين المجانية
  reviewedTraineeRequests TraineeRequest[] // طلبات المتدربين المجانية التي راجعها
  
  // العلاقة مع الشكاوي والاقتراحات
  reviewedComplaints ComplaintSuggestion[] // الشكاوي والاقتراحات التي راجعها

  // العلاقة مع تظلمات الدرجات
  reviewedGradeAppeals GradeAppeal[] @relation("GradeAppealReviewer")

  // العلاقة مع الاستبيانات
  createdSurveys Survey[] @relation("SurveyCreator") // الاستبيانات التي أنشأها

  // العلاقة مع النسخ الاحتياطية
  backups BackupLog[] @relation("UserBackups") // النسخ الاحتياطية التي قام بإنشائها

  // العلاقة مع قيود الدور الثاني
  secondRoundFeeApplications SecondRoundFeeApplication[] @relation("SecondRoundFeeAppliedBy")

  // العلاقة مع البرامج التدريبية المسموح الوصول إليها
  allowedPrograms UserProgramAccess[] // البرامج التدريبية المسموح للمستخدم بالوصول إليها

  // نظام حضور الموظفين
  staffAttendanceEnrollment  StaffAttendanceEnrollment?  @relation("StaffAttendanceEnrollment")
  staffAttendanceEnrollments StaffAttendanceEnrollment[] @relation("StaffAttendanceEnroller")
  staffAttendanceLogs        StaffAttendanceLog[]        @relation("StaffAttendanceLogs")
  staffLeaveRequests         StaffLeaveRequest[]         @relation("StaffLeaveRequests")
  staffLeaveReviews          StaffLeaveRequest[]         @relation("StaffLeaveReviewer")
}

// جدول منفصل للمتدربين مع نظام مصادقة خاص بهم
model TraineeAuth {
  id                 String             @id @default(cuid())
  nationalId         String             @unique // الرقم القومي (مطلوب وفريد)
  birthDate          DateTime           // تاريخ الميلاد للتحقق
  password           String?            // كلمة المرور (اختيارية في البداية)
  isActive           Boolean            @default(true) // حالة نشاط المتدرب
  lastLoginAt        DateTime?          // آخر تسجيل دخول
  // إعادة تعيين كلمة المرور
  resetCode          String?            // كود إعادة تعيين كلمة المرور
  resetCodeExpiresAt DateTime?          // تاريخ انتهاء كود إعادة التعيين
  resetCodeGeneratedAt DateTime?        // تاريخ توليد الكود
  // ربط مع بيانات المتدرب الأساسية
  traineeId          Int                @unique // ربط مع جدول Trainee
  trainee            Trainee            @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  
  // العلاقات الجديدة للتتبع
  sessions           TraineeSession[]   // جلسات المتدرب
  stats              TraineeStats?      // إحصائيات المتدرب
  
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt

  @@map("trainee_auth")
}

model Registration {
  id             Int      @id @default(autoincrement())
  traineeName    String
  phoneNumber    String
  altPhoneNumber String?
  qualification  String // متوسط / عالي
  branch         String // المنصورة / الزقازيق
  program        String // مساعد خدمات صحية / المساحة والانشاءات / تكنولوجيا المعلومات
  friendName     String?
  friendPhone    String?
  createdAt      DateTime @default(now())

  @@map("registrations")
}

model Job {
  id           Int      @id @default(autoincrement())
  title        String   @db.VarChar(255)
  company      String   @db.VarChar(255)
  location     String   @db.VarChar(255)
  type         String   @db.VarChar(100)
  salary       String?  @db.VarChar(100)
  description  String   @db.Text
  requirements String   @db.Text
  applyUrl     String   @db.VarChar(255)
  category     String   @db.VarChar(100)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@map("jobs")
}

model News {
  id          Int      @id @default(autoincrement())
  title       String   @db.VarChar(255)
  content     String   @db.Text
  excerpt     String   @db.Text
  image       String   @db.VarChar(255)
  imageCloudinaryId String? // معرف صورة الخبر في Cloudinary
  author      String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(255)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  @@map("news")
}

// Training Program Models
model TrainingProgram {
  id               Int               @id @default(autoincrement())
  nameAr           String
  nameEn           String
  price            Float
  description      String?
  numberOfClassrooms Int            @default(0) // عدد الفصول الدراسية
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt
  trainees         Trainee[]
  trainingContents TrainingContent[]
  traineeFees      TraineeFee[]
  idCardDesigns    IdCardDesign[]    // تصاميم الكارنيهات المرتبطة بهذا البرنامج
  distributions    TraineeDistribution[] // توزيعات المتدربين على القاعات
  classrooms       Classroom[]       // الفصول الدراسية
  studyMaterials   StudyMaterial[]   // الأدوات الدراسية المرتبطة بهذا البرنامج
  gradeReleaseSettings GradeReleaseSettings[] // إعدادات إعلان الدرجات
  surveys          SurveyProgram[]   // الاستبيانات المرتبطة بهذا البرنامج
  gradeAppealFeeConfig GradeAppealFeeConfig? // إعدادات رسوم التظلمات
  allowedUsers         UserProgramAccess[]   // المستخدمون المسموح لهم بالوصول لهذا البرنامج
}

// جدول ربط المستخدمين بالبرامج التدريبية المسموح لهم بالوصول إليها
// إذا لم يكن للمستخدم أي سجلات هنا = مسموح له بكل البرامج
model UserProgramAccess {
  id        Int              @id @default(autoincrement())
  userId    String
  programId Int
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  program   TrainingProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
  createdAt DateTime         @default(now())

  @@unique([userId, programId])
  @@index([userId])
  @@index([programId])
}

model Classroom {
  id          Int            @id @default(autoincrement())
  name        String         // اسم الفصل (يُنشأ تلقائياً: الفصل 1، الفصل 2...)
  classNumber Int            // رقم الفصل
  programId   Int            // البرنامج التدريبي
  program     TrainingProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  startDate   DateTime?      // تاريخ بداية الفصل الدراسي
  endDate     DateTime?      // تاريخ نهاية الفصل الدراسي
  trainingContents TrainingContent[] // المحتوى التدريبي المرتبط بهذا الفصل
  scheduleSlots    ScheduleSlot[]    // الجدول الدراسي (الفترات الأسبوعية)
  grades           TraineeGrades[]   // درجات المتدربين في هذا الفصل
  distributions    TraineeDistribution[] // توزيعات المتدربين لهذا الفصل
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([programId, classNumber]) // فصل واحد لكل رقم في كل برنامج
  @@map("classrooms")
}

enum EnrollmentType {
  REGULAR // انتظام
  DISTANCE // انتساب
  BOTH // الكل
}

enum MaritalStatus {
  SINGLE // أعزب
  MARRIED // متزوج
  DIVORCED // مطلق
  WIDOWED // أرمل
}

enum ProgramType {
  SUMMER // برنامج صيفي
  WINTER // برنامج شتوي
  ANNUAL // عقد سنة
}

enum Gender {
  MALE // ذكر
  FEMALE // أنثى
}

enum Religion {
  ISLAM // الإسلام
  CHRISTIANITY // المسيحية
  JUDAISM // اليهودية
}

enum EducationType {
  PREPARATORY // اعدادي
  INDUSTRIAL_SECONDARY // ثانوي فني صناعي
  COMMERCIAL_SECONDARY // ثانوي فني تجاري
  AGRICULTURAL_SECONDARY // ثانوي فني زراعي
  AZHAR_SECONDARY // ثانوي أزهري
  GENERAL_SECONDARY // ثانوي عام
  UNIVERSITY // بكالوريوس - ليسانس
  INDUSTRIAL_APPRENTICESHIP // تلمذة صناعية
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN_SUCCESS
  LOGIN_FAILURE
}

model AuditLog {
  id        Int         @id @default(autoincrement())
  action    AuditAction // CREATE, UPDATE, DELETE, LOGIN_SUCCESS, etc.
  entity    String // e.g., "Trainee", "Program", "User"
  entityId  String // ID of the affected entity
  details   Json? // Store before/after state as JSON
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime    @default(now())
}

// حالة المتدرب
enum TraineeStatus {
  NEW // مستجد
  CURRENT // مستمر
  GRADUATE // خريج
  WITHDRAWN // منسحب
}

model Trainee {
  id                  Int             @id @default(autoincrement())
  nameAr              String // الاسم بالعربية
  nameEn              String // الاسم بالإنجليزية
  enrollmentType      EnrollmentType // نطاق الالتحاق
  maritalStatus       MaritalStatus // الحالة الاجتماعية
  nationalId          String          @unique // الرقم القومي
  idIssueDate         DateTime // تاريخ إصدار البطاقة
  idExpiryDate        DateTime // تاريخ انتهاء البطاقة
  programType         ProgramType // نوع البرنامج
  nationality         String // الجنسية
  gender              Gender // النوع
  birthDate           DateTime // تاريخ الميلاد
  residenceAddress    String // محل الإقامة
  photoUrl            String? // صورة المتدرب
  photoCloudinaryId   String? // معرف الصورة في Cloudinary
  religion            Religion        @default(ISLAM) // الديانة
  programId           Int // البرنامج
  program             TrainingProgram @relation(fields: [programId], references: [id])
  country             String // الدولة
  governorate         String? // المحافظة
  city                String // المدينة
  address             String // العنوان
  phone               String // رقم الهاتف
  email               String?         @unique // البريد الإلكتروني
  guardianPhone       String // رقم هاتف ولي الأمر
  guardianEmail       String? // بريد ولي الأمر
  guardianJob         String? // وظيفة ولي الأمر
  guardianRelation    String // صلة القرابة
  guardianName        String  // اسم ولي الأمر
  landline            String? // الهاتف الأرضي
  whatsapp            String? // رقم الواتساب
  facebook            String? // حساب فيسبوك
  educationType       EducationType // نوع المؤهل
  schoolName          String // اسم المدرسة/المعهد
  educationalAdministration String? // الإدارة التعليمية
  graduationDate      DateTime // تاريخ التخرج
  totalGrade          Float? // المجموع الكلي
  gradePercentage     Float? // النسبة المئوية
  sportsActivity      String? // النشاط الرياضي
  culturalActivity    String? // النشاط الثقافي
  educationalActivity String? // النشاط التعليمي
  notes               String? // ملاحظات
  traineeStatus       TraineeStatus   @default(NEW) // حالة المتدرب (مستجد/مستمر/خريج/منسحب)
  classLevel          Year            @default(FIRST) // الفرقة الدراسية
  academicYear        String? // العام الدراسي (مثل "2025/2026")

  // ربط مع موظف التسويق المسؤول عن جلب المتدرب
  marketingEmployeeId Int? // معرف موظف التسويق (اختياري)
  marketingEmployee   MarketingEmployee? @relation(fields: [marketingEmployeeId], references: [id], onDelete: SetNull)

  // نظام التواصل الأول والثاني للتسويق
  firstContactEmployeeId  Int? // معرف موظف التواصل الأول
  firstContactEmployee    MarketingEmployee? @relation("FirstContact", fields: [firstContactEmployeeId], references: [id], onDelete: SetNull)
  secondContactEmployeeId Int? // معرف موظف التواصل الثاني
  secondContactEmployee   MarketingEmployee? @relation("SecondContact", fields: [secondContactEmployeeId], references: [id], onDelete: SetNull)
  
  // علاقات العمولات
  commissions             Commission[]

  // تتبع من أنشأ وعدّل المتدرب
  createdById         String? // من أنشأ المتدرب
  createdBy           User?   @relation("TraineeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById         String? // آخر من عدّل المتدرب
  updatedBy           User?   @relation("TraineeUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  // العلاقة مع سجلات الحضور
  attendanceRecords AttendanceRecord[]
  idCardPrints      IdCardPrint[] // العلاقة مع عمليات طباعة الكارنيه
  
  // إضافة العلاقة مع مدفوعات المتدربين
  traineePayments   TraineePayment[]
  
  // العلاقة مع أرشيف الوثائق
  documents         TraineeDocument[]
  
  // العلاقة مع نظام المصادقة الخاص بالمتدربين
  traineeAuth       TraineeAuth?
  
  // العلاقة مع حملات الواتساب
  campaignRecipients CampaignRecipient[]
  
  // العلاقة مع توزيع القاعات
  distributionAssignments DistributionAssignment[]
  
  // سجلات الحضور
  attendance      Attendance[]
  
  // العلاقة مع ملاحظات المتدربين
  traineeNotes TraineeNote[]
  
  // العلاقة مع سجل التعديلات
  editHistory TraineeEditHistory[]
  
  // العلاقة مع درجات المتدربين
  grades TraineeGrades[]
  
  // العلاقة مع محاولات الاختبارات
  quizAttempts QuizAttempt[]
  
  // العلاقة مع الاختبارات الورقية
  paperAnswerSheets PaperAnswerSheet[] // أوراق الإجابة الورقية
  
  // العلاقة مع الأدوات الدراسية
  studyMaterialDeliveries StudyMaterialDelivery[]
  
  // العلاقة مع استثناءات مواعيد السداد
  paymentExceptions TraineePaymentException[]
  
  // العلاقة مع طلبات تأجيل السداد
  deferralRequests PaymentDeferralRequest[]
  
  // العلاقة مع رسائل التذكير التلقائية
  reminderDeliveries PaymentReminderDelivery[] // الرسائل المرسلة لهذا المتدرب
  
  // العلاقة مع الإجراءات العقابية
  disciplinaryActions DisciplinaryAction[] // الإجراءات العقابية المتخذة ضد المتدرب
  
  // العلاقة مع الطلبات المجانية
  traineeRequests TraineeRequest[] // طلبات المتدرب المجانية (تأجيل اختبار، إجازة، إثبات قيد، إفادة)
  
  // العلاقة مع الشكاوي والاقتراحات
  complaints ComplaintSuggestion[] // شكاوي واقتراحات المتدرب

  // العلاقة مع تظلمات الدرجات
  gradeAppeals GradeAppeal[] // تظلمات الدرجات المقدمة من المتدرب

  // العلاقة مع إجابات الاستبيانات
  surveyResponses SurveyResponse[] // إجابات المتدرب على الاستبيانات

  // العلاقة مع قيود الدور الثاني
  secondRoundFeeApplications SecondRoundFeeApplication[] // قيود الدور الثاني المطبقة
}

// نموذج سجل تعديلات المتدربين
model TraineeEditHistory {
  id         String   @id @default(cuid())
  traineeId  Int
  trainee    Trainee  @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String   // CREATE أو UPDATE
  changes    Json     // التغييرات التي تمت (قبل وبعد)
  createdAt  DateTime @default(now())

  @@index([traineeId])
  @@index([userId])
  @@map("trainee_edit_history")
}

// نموذج ملاحظات المتدربين
model TraineeNote {
  id        String   @id @default(cuid())
  traineeId Int
  trainee   Trainee  @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String   @db.Text // محتوى الملاحظة
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([traineeId])
  @@index([userId])
  @@map("trainee_notes")
}

// نموذج درجات المتدربين
model TraineeGrades {
  id                  Int             @id @default(autoincrement())
  traineeId           Int             // المتدرب
  trainee             Trainee         @relation(fields: [traineeId], references: [id], onDelete: Cascade)
  
  trainingContentId   Int             // المادة التدريبية
  trainingContent     TrainingContent @relation(fields: [trainingContentId], references: [id], onDelete: Cascade)
  
  classroomId         Int             // الفصل الدراسي
  classroom           Classroom       @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  
  // الدرجات الفعلية التي حصل عليها المتدرب
  yearWorkMarks       Float?          @default(0) // درجات أعمال السنة
  practicalMarks      Float?          @default(0) // درجات العملي
  writtenMarks        Float?          @default(0) // درجات التحريري
  attendanceMarks     Float?          @default(0) // درجات الحضور
  quizzesMarks        Float?          @default(0) // درجات اختبارات مصغرة
  finalExamMarks      Float?          @default(0) // درجات الميد تيرم
  
  // الدرجة النهائية
  totalMarks          Float?          @default(0) // مجموع الدرجات
  
  notes               String?         @db.Text // ملاحظات على الدرجات
  
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  
  // فهرس مركب لضمان عدم تكرار السجلات
  @@unique([traineeId, trainingContentId, classroomId])
  @@index([traineeId])
  @@index([trainingContentId])
  @@index([classroomId])
  @@map("trainee_grades")
}

model SystemSettings {
