  centerName                       String // اسم المركز
  centerManagerName                String // اسم مدير المركز
  centerAddress                    String // عنوان المركز
  centerLogo                       String? // صورة لوجو المركز
  centerLogoCloudinaryId           String? // معرف لوجو المركز في Cloudinary
  facebookPageUrl                  String? // رابط صفحة الفيسبوك
  licenseNumber                    String? // رقم ترخيص المركز (اختياري)
  loginUrl                         String? // رابط تسجيل الدخول
