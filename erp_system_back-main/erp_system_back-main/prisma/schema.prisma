  idCardNamePosition           Json? // موضع اسم الطالب في الكارنيه (x, y)
  idCardPhotoPosition          Json? // موضع صورة الطالب في الكارنيه (x, y)
  idCardNationalIdPosition     Json? // موضع الرقم القومي في الكارنيه (x, y)
  idCardProgramPosition        Json? // موضع البرنامج التدريبي في الكارنيه (x, y)
  idCardCenterNamePosition     Json? // موضع اسم المركز في الكارنيه (x, y)
  idCardAdditionalText         String? // نص إضافي في الكارنيه
  idCardAdditionalTextPosition Json? // موضع النص الإضافي في الكارنيه (x, y)
  idCardQrCodePosition         Json? // موضع QR Code في الكارنيه (x, y)
  idCardWidth                  Int     @default(320) // عرض الكارنيه بالبكسل
  idCardHeight                 Int     @default(200) // ارتفاع الكارنيه بالبكسل

  // إعدادات حجم عناصر الكارنيه
  idCardLogoSize           Json? // حجم اللوجو (width, height)
  idCardPhotoSize          Json? // حجم صورة المتدرب (width, height)
  idCardNameSize           Int? // حجم خط اسم المتدرب
  idCardNationalIdSize     Int? // حجم خط الرقم القومي
  idCardProgramSize        Int? // حجم خط اسم البرنامج
  idCardCenterNameSize     Int? // حجم خط اسم المركز
  idCardAdditionalTextSize Int? // حجم خط النص الإضافي
  idCardQrCodeSize         Json? // حجم QR Code (width, height)

  // إعدادات ظهور عناصر الكارنيه
  idCardLogoVisible           Boolean? // إظهار لوجو المركز
  idCardPhotoVisible          Boolean? // إظهار صورة المتدرب
  idCardNameVisible           Boolean? // إظهار اسم المتدرب
  idCardNationalIdVisible     Boolean? // إظهار الرقم القومي
  idCardProgramVisible        Boolean? // إظهار اسم البرنامج
  idCardCenterNameVisible     Boolean? // إظهار اسم المركز
  idCardAdditionalTextVisible Boolean? // إظهار النص الإضافي
  idCardQrCodeVisible         Boolean? // إظهار QR Code

