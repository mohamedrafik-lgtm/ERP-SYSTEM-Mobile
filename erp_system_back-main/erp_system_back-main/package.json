{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npx nest build",
    "copy-wrapper": "powershell -Command \"New-Item -ItemType Directory -Force -Path dist/src/whatsapp; Copy-Item src/whatsapp/baileys-wrapper.mjs dist/src/whatsapp/; Copy-Item src/whatsapp/database-baileys-wrapper.mjs dist/src/whatsapp/; Copy-Item src/whatsapp/baileys-wrapper-v2.mjs dist/src/whatsapp/\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "db:setup": "npx prisma generate && npx prisma db push && npx prisma db seed",
    "db:setup:migrate": "npx prisma generate && npx prisma migrate deploy && npx prisma db seed",
    "db:push": "npx prisma db push --skip-generate",
    "db:seed": "npx prisma db seed",
    "start": "npx prisma generate && npx prisma db push && npx prisma db seed && npx nest start",
    "start:dev": "npx prisma generate && npx prisma db push && npx prisma db seed && npx nest start --watch",
    "start:debug": "npx nest start --debug --watch",
    "start:prod": "node dist/main",
    "prestart:prod": "npm run db:setup:migrate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:seed": "ts-node prisma/seed.ts",
    "test:production-fixes": "node scripts/test-production-fixes.js",
    "start:with-redis": "powershell -ExecutionPolicy Bypass -File start-with-redis.ps1",
    "start:production": "npm run build && npm run db:setup:migrate && npm run start:prod",
    "migrate:whatsapp": "node scripts/migrate-whatsapp-sessions.js"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.4",
    "@google/generative-ai": "^0.21.0",
    "@hapi/boom": "^10.0.1",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.10.1",
    "@types/html-pdf": "^3.0.3",
    "@types/multer": "^1.4.13",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^10.0.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cloudinary": "^2.8.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.7.0",
    "jspdf": "^3.0.2",
    "moment-timezone": "^0.6.0",
    "multer": "^2.0.1",
    "multer-storage-cloudinary": "^2.2.1",
    "openai": "^6.16.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pino": "^10.0.0",
    "prisma": "^6.10.1",
    "puppeteer": "^24.22.2",
    "qr-image": "^3.2.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/qr-image": "^3.2.9",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
