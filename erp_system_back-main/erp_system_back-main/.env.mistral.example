# ====================================
# Mistral AI Configuration
# ====================================

# احصل على API Key من: https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your-mistral-api-key-here

# مثال:
# MISTRAL_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# النماذج المستخدمة:
# - pixtral-large-latest: للتعرف على أوراق OMR (Vision)
# - mistral-large-latest: للمحادثات واستخراج الأسئلة (Text)
