'use client';

import { useState, useEffect } from 'react';
import Link from 'next/link';
import {
  ArrowLeftIcon,
  CalendarDaysIcon,
  CheckCircleIcon,
  XCircleIcon,
  ClockIcon,
  ExclamationCircleIcon,
  AcademicCapIcon,
  ChartBarIcon,
  UserIcon,
} from '@heroicons/react/24/outline';
import LoadingScreen from '../components/LoadingScreen';
import { traineeAttendanceAPI, type TraineeAttendanceData, type ClassroomGroup } from '@/lib/trainee-attendance-api';
import { toast } from 'react-hot-toast';

const dayOfWeekMap: Record<string, string> = {
  SUNDAY: 'الأحد',
  MONDAY: 'الاثنين',
  TUESDAY: 'الثلاثاء',
  WEDNESDAY: 'الأربعاء',
  THURSDAY: 'الخميس',
  FRIDAY: 'الجمعة',
  SATURDAY: 'السبت',
};

const sessionTypeMap: Record<string, string> = {
  THEORETICAL: 'نظري',
  PRACTICAL: 'عملي',
};

const statusMap: Record<string, { label: string; color: string; bgColor: string; icon: any }> = {
  PRESENT: {
    label: 'حاضر',
    color: 'text-green-800',
    bgColor: 'bg-green-100 border-green-200',
    icon: CheckCircleIcon,
  },
  ABSENT: {
    label: 'غائب',
    color: 'text-red-800',
    bgColor: 'bg-red-100 border-red-200',
    icon: XCircleIcon,
  },
  LATE: {
    label: 'متأخر',
    color: 'text-yellow-800',
    bgColor: 'bg-yellow-100 border-yellow-200',
    icon: ClockIcon,
  },
  EXCUSED: {
    label: 'بعذر',
    color: 'text-blue-800',
    bgColor: 'bg-blue-100 border-blue-200',
    icon: ExclamationCircleIcon,
  },
};

export default function AttendancePage() {
  const [loading, setLoading] = useState(true);
  const [data, setData] = useState<TraineeAttendanceData | null>(null);
  const [expandedContent, setExpandedContent] = useState<number | null>(null);
  const [activeClassroomId, setActiveClassroomId] = useState<number | null>(null);

  useEffect(() => {
    fetchAttendanceData();
  }, []);

  const fetchAttendanceData = async () => {
    try {
      setLoading(true);
      const result = await traineeAttendanceAPI.getMyAttendanceRecords();
      setData(result);
      
      // تحديد الفصل الدراسي النشط تلقائياً (الحالي بالتاريخ أو الأحدث)
      if (result.classroomGroups && result.classroomGroups.length > 0) {
        const now = new Date();
        // البحث عن الفصل الحالي بالتاريخ
        const currentClassroom = result.classroomGroups.find((cg: ClassroomGroup) => {
          const start = cg.classroom.startDate ? new Date(cg.classroom.startDate) : null;
          const end = cg.classroom.endDate ? new Date(cg.classroom.endDate) : null;
          return start && end && now >= start && now <= end;
        });
        const selected = currentClassroom || result.classroomGroups[0];
        setActiveClassroomId(selected.classroom.id);
        // فتح أول مادة تلقائياً
        if (selected.contentGroups.length > 0) {
          setExpandedContent(selected.contentGroups[0].content.id);
        }
      } else if (result.contentGroups.length > 0) {
        setExpandedContent(result.contentGroups[0].content.id);
      }
    } catch (error: any) {
      console.error('Error fetching attendance:', error);
      toast.error(error.response?.data?.message || 'فشل تحميل سجلات الحضور');
    } finally {
      setLoading(false);
    }
  };

  const activeClassroomGroup = data?.classroomGroups?.find(
    (g) => g.classroom.id === activeClassroomId
  );

  const hasClassroomGroups = data?.classroomGroups && data.classroomGroups.length > 0;

  const displayContentGroups = hasClassroomGroups
    ? (activeClassroomGroup?.contentGroups || [])
    : (data?.contentGroups || []);

  const displayStats = hasClassroomGroups
    ? (activeClassroomGroup?.stats || data?.stats)
    : data?.stats;

  if (loading) {
    return (
      <LoadingScreen 
        message="جاري تحضير سجل الحضور..." 
        submessage="نجهز لك بيانات المحاضرات"
      />
    );
  }

  if (!data) {
    return (
      <div className="flex items-center justify-center h-64">
        <div className="text-center">
          <XCircleIcon className="w-16 h-16 text-red-500 mx-auto mb-4" />
          <h3 className="text-lg font-semibold text-gray-900 mb-2">حدث خطأ في تحميل البيانات</h3>
          <button
            onClick={fetchAttendanceData}
            className="mt-4 bg-emerald-600 text-white px-4 py-2 rounded-lg hover:bg-emerald-700 transition-colors"
          >
            إعادة المحاولة
          </button>
        </div>
      </div>
    );
  }

  const hasAttendance = data.stats.total > 0;
  const attendancePercentage = data.stats.attendanceRate;

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="mb-6">
        <div className="flex items-center gap-4 mb-4">
          <Link 
            href="/trainee-dashboard" 
            className="p-2 hover:bg-gray-200 rounded-lg transition-colors"
          >
            <ArrowLeftIcon className="w-5 h-5 text-gray-600" />
          </Link>
          <div>
            <h1 className="text-2xl font-bold text-gray-900">سجل الحضور والغياب</h1>
            <p className="text-gray-600">متابعة حضورك في المحاضرات التدريبية</p>
          </div>
        </div>
      </div>

      {/* Attendance Overview */}
      <div className="bg-gradient-to-r from-emerald-500 via-teal-600 to-cyan-600 rounded-2xl p-8 text-white shadow-xl">
        <div className="flex items-center justify-between mb-6">
          <div>
            <h2 className="text-2xl font-bold mb-2">نظرة عامة على الحضور</h2>
            <p className="text-emerald-100">سجلك الأكاديمي الحالي</p>
          </div>
          <div className="hidden md:block">
            <div className="w-20 h-20 bg-white/20 backdrop-blur-sm rounded-full flex items-center justify-center">
              {data.trainee.photoUrl ? (
                <img
                  src={data.trainee.photoUrl}
                  alt={data.trainee.nameAr}
                  className="w-full h-full rounded-full object-cover"
                  onError={(e) => {
                    const target = e.target as HTMLImageElement;
                    target.style.display = 'none';
                    const parent = target.parentElement;
                    if (parent) {
                      parent.innerHTML = '<svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>';
                    }
                  }}
                />
              ) : (
                <UserIcon className="w-10 h-10 text-white" />
              )}
            </div>
          </div>
        </div>

        {hasAttendance ? (
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {/* Total Sessions */}
            <div className="bg-white/25 backdrop-blur-sm rounded-xl p-6 border border-white/30 hover:bg-white/30 transition-all duration-300">
              <div className="flex items-center gap-3 mb-3">
                <div className="p-2 bg-white/20 rounded-lg">
                  <ChartBarIcon className="w-6 h-6 text-white" />
                </div>
                <h3 className="text-lg font-semibold text-white">إجمالي المحاضرات</h3>
              </div>
              <p className="text-3xl font-bold text-white">{data.stats.total}</p>
              <p className="text-emerald-100 text-sm mt-1">جميع المحاضرات المجدولة</p>
            </div>

            {/* Present */}
            <div className="bg-white/25 backdrop-blur-sm rounded-xl p-6 border border-white/30 hover:bg-white/30 transition-all duration-300">
              <div className="flex items-center gap-3 mb-3">
                <div className="p-2 bg-white/20 rounded-lg">
                  <CheckCircleIcon className="w-6 h-6 text-white" />
                </div>
                <h3 className="text-lg font-semibold text-white">حضور</h3>
              </div>
              <p className="text-3xl font-bold text-white">{data.stats.present}</p>
              <p className="text-emerald-100 text-sm mt-1">محاضرة حضرتها ✅</p>
            </div>

            {/* Absent */}
            <div className="bg-white/25 backdrop-blur-sm rounded-xl p-6 border border-white/30 hover:bg-white/30 transition-all duration-300">
              <div className="flex items-center gap-3 mb-3">
                <div className="p-2 bg-white/20 rounded-lg">
                  <XCircleIcon className="w-6 h-6 text-white" />
                </div>
                <h3 className="text-lg font-semibold text-white">غياب</h3>
              </div>
              <p className="text-3xl font-bold text-white">{data.stats.absent}</p>
              <p className="text-emerald-100 text-sm mt-1">محاضرة غبت عنها</p>
            </div>

            {/* Attendance Rate */}
            <div className="bg-white/25 backdrop-blur-sm rounded-xl p-6 border border-white/30 hover:bg-white/30 transition-all duration-300">
              <div className="flex items-center gap-3 mb-3">
                <div className="p-2 bg-white/20 rounded-lg">
                  <CalendarDaysIcon className="w-6 h-6 text-white" />
                </div>
                <h3 className="text-lg font-semibold text-white">نسبة الحضور</h3>
              </div>
              <p className="text-3xl font-bold text-white">{attendancePercentage}%</p>
              <div className="mt-3 bg-white/20 rounded-full h-2">
                <div 
                  className="bg-white rounded-full h-2 transition-all duration-500"
                  style={{ width: `${attendancePercentage}%` }}
                />
              </div>
            </div>
          </div>
        ) : (
          <div className="bg-white/25 backdrop-blur-sm rounded-xl p-8 border border-white/30 text-center">
            <CalendarDaysIcon className="w-16 h-16 text-white mx-auto mb-4" />
            <h3 className="text-xl font-bold text-white mb-2">لم تبدأ المحاضرات بعد</h3>
            <p className="text-emerald-100">
              سيتم تسجيل حضورك تلقائياً عند بدء الجلسات التدريبية
            </p>
          </div>
        )}
      </div>

      {/* Classroom Tabs */}
      {hasClassroomGroups && data.classroomGroups!.length > 1 && (
        <div className="bg-white rounded-xl shadow-lg border border-gray-100 p-4">
          <h2 className="text-lg font-bold text-gray-900 mb-3 flex items-center gap-2">
            <AcademicCapIcon className="w-5 h-5 text-emerald-600" />
            الفصول الدراسية
          </h2>
          <div className="flex flex-wrap gap-2">
            {data.classroomGroups!.map((cg) => {
              const isActive = cg.classroom.id === activeClassroomId;
              const now = new Date();
              const start = cg.classroom.startDate ? new Date(cg.classroom.startDate) : null;
              const end = cg.classroom.endDate ? new Date(cg.classroom.endDate) : null;
              const isCurrent = start && end && now >= start && now <= end;
              return (
                <button
                  key={cg.classroom.id}
                  onClick={() => {
                    setActiveClassroomId(cg.classroom.id);
                    setExpandedContent(cg.contentGroups.length > 0 ? cg.contentGroups[0].content.id : null);
                  }}
                  className={`px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 border ${
                    isActive
                      ? 'bg-emerald-600 text-white border-emerald-600 shadow-md'
                      : 'bg-gray-50 text-gray-700 border-gray-200 hover:bg-gray-100 hover:border-gray-300'
                  }`}
                >
                  <div className="flex items-center gap-2">
                    <span>{cg.classroom.name}</span>
                    {isCurrent && (
                      <span className={`w-2 h-2 rounded-full ${isActive ? 'bg-white' : 'bg-emerald-500'} animate-pulse`} />
                    )}
                  </div>
                  {start && (
                    <div className={`text-xs mt-1 ${isActive ? 'text-emerald-100' : 'text-gray-500'}`}>
                      {start.toLocaleDateString('ar-EG', { month: 'short', year: 'numeric' })}
                      {end && ` - ${end.toLocaleDateString('ar-EG', { month: 'short', year: 'numeric' })}`}
                    </div>
                  )}
                </button>
              );
            })}
          </div>
        </div>
      )}

      {/* Per-Classroom Stats */}
      {hasClassroomGroups && activeClassroomGroup && displayStats && (
        <div className="bg-white rounded-xl shadow-lg border border-gray-100 p-6">
          <div className="flex items-center justify-between mb-4">
            <h3 className="text-lg font-bold text-gray-900">
              إحصائيات: {activeClassroomGroup.classroom.name}
            </h3>
            <span className={`text-2xl font-bold ${
              displayStats.attendanceRate >= 80 ? 'text-green-600' :
              displayStats.attendanceRate >= 70 ? 'text-yellow-600' : 'text-red-600'
            }`}>
              {displayStats.attendanceRate}%
            </span>
          </div>
          <div className="grid grid-cols-2 sm:grid-cols-4 gap-4">
            <div className="text-center p-3 bg-gray-50 rounded-lg">
              <p className="text-2xl font-bold text-gray-800">{displayStats.total}</p>
              <p className="text-xs text-gray-500">إجمالي</p>
            </div>
            <div className="text-center p-3 bg-green-50 rounded-lg">
              <p className="text-2xl font-bold text-green-600">{displayStats.present}</p>
              <p className="text-xs text-gray-500">حضور</p>
            </div>
            <div className="text-center p-3 bg-red-50 rounded-lg">
              <p className="text-2xl font-bold text-red-600">{displayStats.absent}</p>
              <p className="text-xs text-gray-500">غياب</p>
            </div>
            <div className="text-center p-3 bg-yellow-50 rounded-lg">
              <p className="text-2xl font-bold text-yellow-600">{displayStats.late}</p>
              <p className="text-xs text-gray-500">تأخير</p>
            </div>
          </div>
        </div>
      )}

      {/* Content Groups */}
      {(hasAttendance || hasClassroomGroups) && (
        <div className="space-y-4">
          <h2 className="text-xl font-bold text-gray-900 flex items-center gap-2">
            <AcademicCapIcon className="w-6 h-6 text-emerald-600" />
            سجل الحضور حسب المواد التدريبية
            {hasClassroomGroups && activeClassroomGroup && (
              <span className="text-sm font-normal text-gray-500">— {activeClassroomGroup.classroom.name}</span>
            )}
          </h2>

          {displayContentGroups.length === 0 && (
            <div className="bg-white rounded-xl shadow p-8 text-center text-gray-500">
              <CalendarDaysIcon className="w-12 h-12 text-gray-300 mx-auto mb-3" />
              <p>لا توجد سجلات حضور لهذا الفصل الدراسي</p>
            </div>
          )}

          {displayContentGroups.map((group) => (
            <div 
              key={group.content.id}
              className="bg-white rounded-xl shadow-lg border border-gray-100"
            >
              {/* Content Header */}
              <button
                onClick={() => setExpandedContent(expandedContent === group.content.id ? null : group.content.id)}
                className="w-full p-6 flex items-center justify-between hover:bg-gray-50 transition-colors rounded-xl"
              >
                <div className="flex items-center gap-4">
                  <div className="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center text-white font-bold text-xl shadow-md">
                    {group.content.nameAr.charAt(0)}
                  </div>
                  <div className="text-right">
                    <h3 className="text-lg font-bold text-gray-900">{group.content.nameAr}</h3>
                    <div className="flex items-center gap-4 mt-1 text-sm text-gray-600">
                      <span>{group.stats.total} محاضرة</span>
                      <span>•</span>
                      <span className={`font-medium ${
                        group.stats.attendanceRate >= 80 ? 'text-green-600' :
                        group.stats.attendanceRate >= 70 ? 'text-yellow-600' : 'text-red-600'
                      }`}>
                        {group.stats.attendanceRate}% نسبة الحضور
                      </span>
                    </div>
                  </div>
                </div>

                <div className="flex items-center gap-4">
                  <div className="hidden sm:flex items-center gap-3">
                    <div className="text-center">
                      <p className="text-2xl font-bold text-green-600">{group.stats.present}</p>
                      <p className="text-xs text-gray-500">حضور</p>
                    </div>
                    <div className="text-center">
                      <p className="text-2xl font-bold text-red-600">{group.stats.absent}</p>
                      <p className="text-xs text-gray-500">غياب</p>
                    </div>
                    {group.stats.late > 0 && (
                      <div className="text-center">
                        <p className="text-2xl font-bold text-yellow-600">{group.stats.late}</p>
                        <p className="text-xs text-gray-500">تأخير</p>
                      </div>
                    )}
                  </div>

                  <svg
                    className={`w-6 h-6 text-gray-400 transition-transform duration-300 ${
                      expandedContent === group.content.id ? 'rotate-180' : ''
                    }`}
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M19 9l-7 7-7-7" />
                  </svg>
                </div>
              </button>

              {/* Sessions List */}
              {expandedContent === group.content.id && (
                <div className="border-t border-gray-200 bg-gray-50 p-6">
                  <div className="space-y-3">
                    {group.sessions.map((session) => {
                      const statusInfo = statusMap[session.status];
                      const StatusIcon = statusInfo.icon;

                      return (
                        <div
                          key={session.id}
                          className={`bg-white rounded-lg p-4 border ${statusInfo.bgColor} hover:shadow-md transition-shadow`}
                        >
                          <div className="flex items-start justify-between gap-4">
                            <div className="flex items-start gap-3 flex-1">
                              <div className={`p-2 ${statusInfo.bgColor} rounded-lg`}>
                                <StatusIcon className={`w-5 h-5 ${statusInfo.color}`} />
                              </div>
                              <div className="flex-1">
                                <div className="flex items-center gap-2 flex-wrap mb-2">
                                  <span className="font-bold text-gray-900">
                                    {dayOfWeekMap[session.dayOfWeek]}
                                  </span>
                                  <span className="text-gray-400">•</span>
                                  <span className="text-gray-600">
                                    {new Date(session.date).toLocaleDateString('ar-EG', {
                                      year: 'numeric',
                                      month: 'long',
                                      day: 'numeric'
                                    })}
                                  </span>
                                  <span className="text-gray-400">•</span>
                                  <span className={`px-2 py-0.5 rounded text-xs font-medium border ${
                                    session.sessionType === 'THEORETICAL' 
                                      ? 'bg-blue-50 text-blue-700 border-blue-200' 
                                      : 'bg-purple-50 text-purple-700 border-purple-200'
                                  }`}>
                                    {sessionTypeMap[session.sessionType]}
                                  </span>
                                </div>
                                {session.notes && (
                                  <p className="text-sm text-gray-600 mt-2 bg-gray-50 p-2 rounded">
                                    📝 {session.notes}
                                  </p>
                                )}
                                {session.isCancelled && (
                                  <p className="text-sm text-yellow-700 mt-2 flex items-center gap-1 font-medium">
                                    <ExclamationCircleIcon className="w-4 h-4" />
                                    محاضرة ملغاة
                                  </p>
                                )}
                              </div>
                            </div>

                            <span className={`px-3 py-1.5 rounded-lg text-sm font-bold border ${statusInfo.bgColor} ${statusInfo.color} whitespace-nowrap`}>
                              {statusInfo.label}
                            </span>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}
